# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

# Notion
NOTION_TOKEN=ntn_...
# The DATABASE's own page UUID (from its Notion URL), NOT its data source
# UUID (the "collection://..." id shown in Notion's internal fetch tools) --
# these are different ids and using the wrong one causes a 404.
NOTION_DATA_SOURCE_ID=0a7e2f37-cd93-4d77-9d47-98c3943f6606

# Google OAuth (Gmail API, installed-app flow)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Limits
MAX_EMAILS_PER_RUN=20

# Story Scout AI (separate module, separate Notion database -- see README)
# Same "database page UUID, not data source UUID" caveat as NOTION_DATA_SOURCE_ID above.
NOTION_STORY_DATABASE_ID=...
STORY_SCOUT_LOOKBACK_DAYS=4
STORY_SCOUT_TOP_N=5
# Reuses the GOOGLE_* credentials above to send its digest email.
STORY_SCOUT_NOTIFY_EMAIL=you@example.com
STORY_SCOUT_RECIPIENT_NAME=Nicole

# Optional: Reddit (a free "script" app at reddit.com/prefs/apps). Reddit is
# skipped, not a hard failure, if these are unset.
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...

# Optional: YouTube Data API v3 key (console.cloud.google.com, enable
# "YouTube Data API v3", create an API key). YouTube is skipped, not a hard
# failure, if this is unset.
YOUTUBE_API_KEY=...
