# LLM provider selection -- one of: anthropic, openai, gemini
# Only the selected provider's API key below is required.
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# Notion
NOTION_TOKEN=ntn_...
# The DATABASE's own page UUID (from its Notion URL), NOT its data source
# UUID (the "collection://..." id shown in Notion's internal fetch tools) --
# these are different ids and using the wrong one causes a 404.
NOTION_DATA_SOURCE_ID=0a7e2f37-cd93-4d77-9d47-98c3943f6606

# Google OAuth (Gmail API, installed-app flow)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Limits
MAX_EMAILS_PER_RUN=20
