# Google Gemini -- required unconditionally. The Morning Job Brief pipeline
# hardcodes the Gemini backend regardless of LLM_PROVIDER below, specifically
# so it never depends on the Anthropic API.
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# LLM_PROVIDER/ANTHROPIC_API_KEY/OPENAI_API_KEY below are only used by the
# shared, provider-agnostic llm_client.py module itself (and its tests) --
# not by job_assistant/main.py, which always uses Gemini. Leave LLM_PROVIDER
# unset (defaults to anthropic) unless you're testing llm_client.py directly
# against a different provider.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Notion
NOTION_TOKEN=ntn_...
# The CRM DATABASE's own page UUID (from its Notion URL), NOT its data source
# UUID (the "collection://..." id shown in Notion's internal fetch tools) --
# these are different ids and using the wrong one causes a 404.
NOTION_DATA_SOURCE_ID=0a7e2f37-cd93-4d77-9d47-98c3943f6606
# A separate database (create it once, minimal schema: Name title + Date
# date) that the daily Morning Brief digest gets written to as a new page.
NOTION_MORNING_BRIEF_DATABASE_ID=...

# Google OAuth (Gmail API, installed-app flow). Scope is gmail.modify (a
# superset of the old readonly+compose) -- needed for Gmail label management,
# which is this pipeline's primary dedup mechanism. If your refresh token was
# minted before this scope change, re-run scripts/local_oauth_bootstrap.py to
# get a new one; the old token won't have label-management permission.
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Limits
MAX_EMAILS_PER_RUN=20
